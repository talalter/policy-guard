# Required — no default, app will not start without this
OPENAI_API_KEY=sk-...

# Environment-specific — change for staging/production
FRONTEND_URL=http://localhost:5173

# Optional overrides — defaults are set in backend/config.py
# Uncomment and change only if you need to deviate from the defaults.

# GPT_MODEL=gpt-4o                    # default; use gpt-4o-mini for dev/cost savings
# NLI_MODEL=dleemiller/ModernCE-large-nli
# BI_ENCODER_MODEL=all-MiniLM-L6-v2
# NLI_TOP_K=5
# NLI_MIN_SIMILARITY=0.25
# NLI_MINI_BATCH_SIZE=8
# NLI_MAX_LENGTH=8192
# NLI_CONFIDENCE_THRESHOLD=0.75
# DIRECT_SEVERITY_THRESHOLD=0.90
# NLI_ESCALATION_FLOOR=0.4
# LLM_MIN_CONFIDENCE=0.85
# LOG_LEVEL=INFO
